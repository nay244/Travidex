{
  "name": "travidex",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo-google-fonts/space-mono": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@supabase/supabase-js": "^2.108.0",
    "expo": "~56.0.9",
    "expo-apple-authentication": "~56.0.4",
    "expo-constants": "~56.0.17",
    "expo-font": "~56.0.5",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.9",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@react-native/jest-preset": "^0.86.0",
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "^29.0.0",
    "@types/react": "~19.2.2",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "^56.0.14",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.4",
    "react-test-renderer": "^19.2.7",
    "test-renderer": "^1.2.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.setup.env.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.tsx"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@supabase/.*))"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@react-native-async-storage/async-storage$": "@react-native-async-storage/async-storage/jest/async-storage-mock",
      "^@expo-google-fonts/(.*)$": "<rootDir>/__mocks__/expo-google-fonts.js",
      "^expo-font$": "<rootDir>/__mocks__/expo-font.js"
    }
  },
  "private": true
}
